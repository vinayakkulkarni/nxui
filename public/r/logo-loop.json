{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "logo-loop",
  "type": "registry:ui",
  "title": "Logo Loop",
  "description": "Infinite scrolling logo marquee with smooth animation and fade edges.",
  "dependencies": [
    "@vueuse/core"
