{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "auth-modal",
  "type": "registry:ui",
  "title": "Auth Modal",
  "description": "An animated authentication modal with sign in and sign up tabs.",
  "dependencies": ["@vueuse/core", "motion-v"],
  "files": [
    {
      "path": "registry/new-york/AuthModal/AuthModalEmail.vue",
      "content": "<script setup lang=\"ts\">\n  const email = defineModel<string>('email', { default: '' });\n\n  const emit = defineEmits<{\n    submit: [email: string];\n  }>();\n\n  function handleSubmit() {\n    if (email.value) {\n      emit('submit', email.value);\n    }\n  }\n</script>\n\n<template>\n  <div class=\"relative\">\n    <Icon\n      name=\"lucide:mail\"\n      class=\"absolute left-3 top-1/2 size-4 -translate-y-1/2 text-zinc-400\"\n    />\n    <input\n      v-model=\"email\"\n      type=\"email\"\n      placeholder=\"name@example.com\"\n      class=\"h-10 w-full rounded-full border border-zinc-200 bg-zinc-50 pl-10 pr-10 text-sm outline-none transition-all focus:border-zinc-900 focus:bg-white focus:ring-1 focus:ring-zinc-900 dark:border-zinc-800 dark:bg-zinc-900/50 dark:focus:border-zinc-100 dark:focus:bg-zinc-900\"\n      @keydown.enter=\"handleSubmit\"\n    />\n    <button\n      class=\"absolute right-1 top-1/2 flex size-8 -translate-y-1/2 items-center justify-center rounded-full bg-zinc-900 text-zinc-50 transition-transform hover:scale-95 active:scale-90 dark:bg-zinc-50 dark:text-zinc-900\"\n      @click=\"handleSubmit\"\n    >\n      <Icon name=\"lucide:arrow-right\" class=\"size-4\" />\n    </button>\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/AuthModal/AuthModalEmail.vue"
    },
    {
      "path": "registry/new-york/AuthModal/AuthModal.vue",
      "content": "<script setup lang=\"ts\">\n  import { motion, AnimatePresence } from 'motion-v';\n  import { cn } from '~/lib/utils';\n  import AuthModalContent from './AuthModalContent.vue';\n\n  const props = withDefaults(\n    defineProps<{\n      class?: string;\n    }>(),\n    { class: '' },\n  );\n\n  const open = defineModel<boolean>('open', { default: false });\n\n  const emit = defineEmits<{\n    login: [provider: string];\n  }>();\n\n  const containerVariants = {\n    hidden: { opacity: 0, scale: 0.95 },\n    show: {\n      opacity: 1,\n      scale: 1,\n      transition: { duration: 0.3, ease: 'easeInOut', staggerChildren: 0.05 },\n    },\n    exit: {\n      opacity: 0,\n      scale: 0.95,\n      transition: { duration: 0.2, ease: 'easeInOut' },\n    },\n  };\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <AnimatePresence>\n      <div\n        v-if=\"open\"\n        class=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n      >\n        <component\n          :is=\"motion.div\"\n          :initial=\"{ opacity: 0 }\"\n          :animate=\"{ opacity: 1 }\"\n          :exit=\"{ opacity: 0 }\"\n          class=\"absolute inset-0 bg-zinc-950/20 backdrop-blur-sm dark:bg-zinc-950/40\"\n          @click=\"open = false\"\n        />\n        <component\n          :is=\"motion.div\"\n          :variants=\"containerVariants\"\n          initial=\"hidden\"\n          animate=\"show\"\n          exit=\"exit\"\n          :class=\"\n            cn(\n              'relative w-full max-w-[360px] overflow-hidden rounded-3xl border border-zinc-100 bg-white p-6 shadow-2xl ring-1 ring-zinc-950/5 dark:border-zinc-900 dark:bg-zinc-950',\n              props.class,\n            )\n          \"\n        >\n          <AuthModalContent\n            @close=\"open = false\"\n            @login=\"emit('login', $event)\"\n          />\n        </component>\n      </div>\n    </AnimatePresence>\n  </Teleport>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/AuthModal/AuthModal.vue"
    },
    {
      "path": "registry/new-york/AuthModal/AuthModalSocials.vue",
      "content": "<script setup lang=\"ts\">\n  import type { SocialProvider } from '~/types/components';\n\n  defineProps<{\n    providers: SocialProvider[];\n  }>();\n\n  const emit = defineEmits<{\n    login: [provider: string];\n  }>();\n</script>\n\n<template>\n  <div class=\"grid grid-cols-5 gap-3\">\n    <button\n      v-for=\"(btn, i) in providers\"\n      :key=\"i\"\n      class=\"flex aspect-square items-center justify-center rounded-2xl border border-zinc-200 bg-white transition-all hover:scale-105 hover:bg-zinc-100 active:scale-95 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-800\"\n      :aria-label=\"`Sign in with ${btn.label}`\"\n      @click=\"emit('login', btn.label)\"\n    >\n      <Icon :name=\"btn.icon\" class=\"size-5\" />\n    </button>\n  </div>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/AuthModal/AuthModalSocials.vue"
    },
    {
      "path": "registry/new-york/AuthModal/AuthModalContent.vue",
      "content": "<script setup lang=\"ts\">\n  import { motion } from 'motion-v';\n  import { useAuthModal } from '~/composables/use-auth-modal';\n  import AuthModalSocials from './AuthModalSocials.vue';\n  import AuthModalEmail from './AuthModalEmail.vue';\n\n  const { socialProviders, staggeredEntry } = useAuthModal();\n\n  const email = ref('');\n\n  const emit = defineEmits<{\n    close: [];\n    login: [provider: string];\n  }>();\n\n  function handleLogin(provider: string) {\n    emit('login', provider);\n  }\n</script>\n\n<template>\n  <div class=\"absolute right-4 top-4\">\n    <button\n      class=\"rounded-full p-2 text-zinc-400 hover:bg-zinc-100 hover:text-zinc-500 dark:hover:bg-zinc-900\"\n      @click=\"emit('close')\"\n    >\n      <Icon name=\"lucide:x\" class=\"size-4\" />\n    </button>\n  </div>\n\n  <component :is=\"motion.div\" v-bind=\"staggeredEntry(0)\" class=\"mb-8 text-center\">\n    <h2 class=\"text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50\">\n      Welcome back\n    </h2>\n    <p class=\"mt-2 text-sm text-zinc-500 dark:text-zinc-400\">\n      Sign in to your account to continue\n    </p>\n  </component>\n\n  <component :is=\"motion.div\" v-bind=\"staggeredEntry(1)\" class=\"mb-8\">\n    <AuthModalSocials :providers=\"socialProviders\" @login=\"handleLogin\" />\n  </component>\n\n  <component :is=\"motion.div\" v-bind=\"staggeredEntry(2)\" class=\"relative mb-8\">\n    <div class=\"absolute inset-0 flex items-center\">\n      <span class=\"w-full border-t border-zinc-200 dark:border-zinc-800\" />\n    </div>\n    <div class=\"relative flex justify-center text-xs uppercase\">\n      <span class=\"bg-white px-2 text-zinc-400 dark:bg-zinc-950\">\n        Or continue with email\n      </span>\n    </div>\n  </component>\n\n  <component :is=\"motion.div\" v-bind=\"staggeredEntry(3)\">\n    <AuthModalEmail v-model:email=\"email\" @submit=\"handleLogin('email')\" />\n  </component>\n\n  <component :is=\"motion.div\" v-bind=\"staggeredEntry(4)\" class=\"mt-8 text-center\">\n    <p class=\"text-xs text-zinc-400\">\n      By clicking continue, you agree to our\n      <a href=\"#\" class=\"underline hover:text-zinc-900 dark:hover:text-zinc-50\">Terms of Service</a>\n      and\n      <a href=\"#\" class=\"underline hover:text-zinc-900 dark:hover:text-zinc-50\">Privacy Policy</a>\n    </p>\n  </component>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/AuthModal/AuthModalContent.vue"
    }
  ]
}
