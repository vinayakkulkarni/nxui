{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "split-text",
  "type": "registry:ui",
  "title": "Split Text",
  "description": "Staggered character or word entrance animation triggered on scroll into view.",
  "dependencies": [
    "@vueuse/core",
    "motion-v"
  ],
  "files": [
    {
      "path": "registry/new-york/SplitText/SplitText.vue",
      "content": "<script setup lang=\"ts\">\n  import { useIntersectionObserver } from '@vueuse/core';\n  import { motion } from 'motion-v';\n  import { cn } from '~/lib/utils';\n\n  const props = withDefaults(\n    defineProps<{\n      text: string;\n      by?: 'chars' | 'words';\n      delay?: number;\n      duration?: number;\n      from?: Record<string, unknown>;\n      to?: Record<string, unknown>;\n      threshold?: number;\n      class?: string;\n    }>(),\n    {\n      by: 'chars',\n      delay: 50,\n      duration: 0.6,\n      from: () => ({ opacity: 0, y: 40 }),\n      to: () => ({ opacity: 1, y: 0 }),\n      threshold: 0.1,\n      class: '',\n    },\n  );\n\n  const el = ref<HTMLElement>();\n  const isInView = ref(false);\n\n  useIntersectionObserver(\n    el,\n    ([entry]) => {\n      if (entry?.isIntersecting) {\n        isInView.value = true;\n      }\n    },\n    { threshold: props.threshold },\n  );\n\n  const words = computed(() => {\n    if (props.by === 'words') {\n      return props.text.split(' ').map((word, i, arr) => ({\n        characters: [word],\n        needsSpace: i < arr.length - 1,\n      }));\n    }\n    return props.text.split(' ').map((word, i, arr) => ({\n      characters: word.split(''),\n      needsSpace: i < arr.length - 1,\n    }));\n  });\n\n  function getDelay(globalIndex: number): number {\n    return (globalIndex * props.delay) / 1000;\n  }\n</script>\n\n<template>\n  <p ref=\"el\" :class=\"cn('flex flex-wrap whitespace-pre-wrap', props.class)\">\n    <span v-for=\"(word, wi) in words\" :key=\"wi\" class=\"inline-flex\">\n      <component\n        :is=\"motion.span\"\n        v-for=\"(char, ci) in word.characters\"\n        :key=\"`${wi}-${ci}`\"\n        class=\"inline-block\"\n        :initial=\"from\"\n        :animate=\"isInView ? to : from\"\n        :transition=\"{\n          duration,\n          delay: getDelay(\n            words.slice(0, wi).reduce((sum, w) => sum + w.characters.length, 0) + ci,\n          ),\n          type: 'spring',\n          damping: 25,\n          stiffness: 300,\n        }\"\n        style=\"will-change: transform, opacity\"\n      >\n        {{ char }}\n      </component>\n      <span v-if=\"word.needsSpace\" class=\"whitespace-pre\">&nbsp;</span>\n    </span>\n  </p>\n</template>\n",
      "type": "registry:ui",
      "target": "components/ui/SplitText/SplitText.vue"
    }
  ]
}
