      "content": "export interface ClosingPlasmaProps {\n  speed?: number;\n  turbulence?: number;\n  mouseInfluence?: number;\n  grain?: number;\n  sparkle?: number;\n  vignette?: number;\n  opacity?: number;\n  interactive?: boolean;\n  darkColorA?: string;\n  darkColorB?: string;\n  darkColorC?: string;\n  lightColorA?: string;\n  lightColorB?: string;\n  lightColorC?: string;\n  class?: string;\n}\n",
      "type": "registry:ui",
