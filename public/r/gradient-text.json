{
  "$schema": "https://shadcn-vue.com/schema/registry-item.json",
  "name": "gradient-text",
  "type": "registry:ui",
  "title": "Gradient Text",
  "description": "Animated flowing gradient across text with customizable colors and speed.",
  "dependencies": [],
  "files": [
    {
      "path": "registry/new-york/GradientText/GradientText.vue",
      "content": "<script setup lang=\"ts\">\n  import { computed } from 'vue';\n  import { cn } from '~/lib/utils';\n\n  const props = withDefaults(\n    defineProps<{\n      text: string;\n      colors?: string[];\n      speed?: number;\n      class?: string;\n    }>(),\n    {\n      colors: () => ['#40ffaa', '#4079ff', '#40ffaa', '#4079ff', '#40ffaa'],\n      speed: 8,\n      class: '',\n    },\n  );\n\n  const gradientStyle = computed(() => ({\n    backgroundImage: `linear-gradient(to right, ${props.colors.join(', ')})`,\n    backgroundSize: '300% 100%',\n    WebkitBackgroundClip: 'text',\n    backgroundClip: 'text',\n    color: 'transparent',\n    animationDuration: `${props.speed}s`,\n  }));\n</script>\n\n<template>\n  <span\n    :class=\"\n      cn(\n        'inline-block animate-[gradient-flow_var(--speed)_linear_infinite]',\n        props.class,\n      )\n    \"\n    :style=\"{ ...gradientStyle, '--speed': `${speed}s` }\"\n  >\n    {{ text }}\n  </span>\n</template>\n\n<style scoped>\n  @keyframes gradient-flow {\n    0% {\n      background-position: 0% 50%;\n    }\n    50% {\n      background-position: 100% 50%;\n    }\n    100% {\n      background-position: 0% 50%;\n    }\n  }\n</style>\n",
      "type": "registry:ui",
      "target": "components/ui/GradientText/GradientText.vue"
    }
  ]
}
