# OpenPanel product analytics (self-hosted at https://events.geoql.in)
# Client ID is public (embedded in the browser bundle for client-side tracking).
NUXT_PUBLIC_OPENPANEL_CLIENT_ID=

# Client secret authenticates server-side track calls (server/utils/openpanel.ts).
# Keep this secret — it must NEVER be committed or exposed to the client.
NUXT_OPENPANEL_CLIENT_SECRET=
